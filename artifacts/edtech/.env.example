# Firebase Web App config
# These VITE_ values must be present in Railway before `pnpm run build`,
# because Vite bakes them into the production frontend bundle.
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=1:1234567890:web:yourfirebaseappid

# Only needed when deploying @workspace/edtech as a separate Railway service.
# This should point at the private URL of the @workspace/api-server service.
API_PROXY_TARGET=http://rankpulse.railway.internal:8080

# Optional Firebase fields
# VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
# VITE_FIREBASE_STORAGE_BUCKET=your-firebase-project-id.firebasestorage.app
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
