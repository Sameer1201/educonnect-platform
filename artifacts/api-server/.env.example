# Core server
PORT=8080
DATABASE_PROVIDER=neon
DATABASE_URL=postgresql://neondb_owner:password@ep-example.ap-south-1.aws.neon.tech/neondb?sslmode=require
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
PUBLIC_APP_URL=https://rankpulse.up.railway.app
# Optional custom secret for signed reset links
# PASSWORD_RESET_LINK_SECRET=choose_a_long_random_secret

# New Google-created student accounts: approved or pending
FIREBASE_GOOGLE_NEW_STUDENT_STATUS=pending

# Razorpay payment setup
# Keep live secrets only in Railway/local env, never in committed code.
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Brevo approval email setup
# BREVO_API_KEY=your_brevo_api_key
# BREVO_SENDER_EMAIL=notifications@yourdomain.com
# BREVO_SENDER_NAME=Rank Pulse
# Optional single-account limits
# BREVO_ACCOUNT_KEY=brevo-primary
# BREVO_DAILY_LIMIT=300
# BREVO_DAILY_SOFT_LIMIT=250
#
# Multi-account rotation (recommended when using several Brevo accounts)
# The mailer uses accounts in the listed order until each reaches dailySoftLimit,
# then uses the remaining quota up to dailyLimit in the same order.
# BREVO_ACCOUNTS_JSON=[
#   {
#     "key":"brevo-1",
#     "apiKey":"first_api_key",
#     "senderEmail":"sameermajhi339@gmail.com",
#     "senderName":"Rank Pulse",
#     "dailyLimit":300,
#     "dailySoftLimit":250
#   },
#   {
#     "key":"brevo-2",
#     "apiKey":"second_api_key",
#     "senderEmail":"sameermajhi339@gmail.com",
#     "senderName":"Rank Pulse",
#     "dailyLimit":300,
#     "dailySoftLimit":250
#   }
# ]

# Firebase Admin setup
# Use one of the options below.

# Optional for token verification fallback when Firebase Admin credentials
# are not available. This enables Firebase email/password and Google login
# verification using Firebase Identity Toolkit.
# FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# Option A: service account file path
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-service-account.json

# Option B: individual service account fields
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Option C: full service account JSON as one env var
# FIREBASE_SERVICE_ACCOUNT_JSON={"projectId":"your-firebase-project-id","clientEmail":"firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com","privateKey":"-----BEGIN PRIVATE KEY-----\\nYOUR_PRIVATE_KEY\\n-----END PRIVATE KEY-----\\n"}
