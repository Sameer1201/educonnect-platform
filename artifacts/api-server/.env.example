# Core server
PORT=8080
DATABASE_URL=postgresql://sameermajhi@localhost:5432/edtech
PUBLIC_APP_URL=http://localhost:5173

# New Google-created student accounts: approved or pending
FIREBASE_GOOGLE_NEW_STUDENT_STATUS=pending

# Brevo approval email setup
# BREVO_API_KEY=your_brevo_api_key
# BREVO_SENDER_EMAIL=notifications@yourdomain.com
# BREVO_SENDER_NAME=Rank Pulse
# BREVO_REPLY_TO_EMAIL=sameermajhi339@gmail.com
# BREVO_REPLY_TO_NAME=Sameer Majhi

# Firebase Admin setup
# Use one of the options below.

# Option A: service account file path
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-service-account.json

# Option B: individual service account fields
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Option C: full service account JSON as one env var
# FIREBASE_SERVICE_ACCOUNT_JSON={"projectId":"your-firebase-project-id","clientEmail":"firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com","privateKey":"-----BEGIN PRIVATE KEY-----\\nYOUR_PRIVATE_KEY\\n-----END PRIVATE KEY-----\\n"}
